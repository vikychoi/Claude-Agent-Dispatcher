# Database and cache
DATABASE_URL=postgresql://taskshed:taskshed@postgres:5432/taskshed
REDIS_URL=redis://redis:6379
POSTGRES_PASSWORD=taskshed

# API server
PORT=3000
SECRET_KEY=                      # 32+ random bytes, hex-encoded. Generate with: openssl rand -hex 32

# Worker
AGENT_IMAGE_TAG=claude-agent:latest
MAX_CONCURRENT_JOBS=3
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_QUOTA=100000
JOB_DATA_DIR=/data/jobs
HOST_JOB_DATA_DIR=               # Absolute path on host, e.g. /home/user/taskshed/data/jobs
DOCKER_GID=                      # Host docker group GID. Find with: getent group docker | cut -d: -f3
